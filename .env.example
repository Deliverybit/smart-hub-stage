# Copy to .env for local scripts (migrations, exports).
# Streamlit staging deploy: use host secrets instead of committing .env.

APP_ENV=staging

# Supabase smart-hub-stage → Connect → Direct → Session pooler → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require

ALPHA_VANTAGE_API_KEY=replace-with-your-alpha-vantage-key
SCREENER_SYMBOL_LIMIT=1000

# Optional: consent_api.py
# CONSENT_API_KEY=generate-a-long-random-secret
# CONSENT_DEFAULT_TIMEZONE=America/Chicago
