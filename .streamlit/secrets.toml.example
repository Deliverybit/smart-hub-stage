APP_ENV = "staging"

ALPHA_VANTAGE_API_KEY = "replace-with-your-alpha-vantage-key"
# Max symbols scanned per screener page. Current universes top out at 83 (NASDAQ).
# 100 keeps full coverage with headroom; 1000 is safe if you expand symbol lists.
SCREENER_SYMBOL_LIMIT = 100

# Supabase smart-hub-stage (Session pooler, port 5432)
# Connect → Direct → Session pooler → URI → append ?sslmode=require
DATABASE_URL = "postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"
